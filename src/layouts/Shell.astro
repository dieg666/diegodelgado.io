---
import { execSync } from "node:child_process";
import { nav, site, type NavKey } from "@/data/site";

interface Props {
  page: NavKey;
  /** Visible path segment in the prompt; defaults from `page`. */
  path?: string;
}

const { page, path } = Astro.props;
const segment = path ?? (page === "home" ? "" : page);

// Last deploy ≈ last commit that made it into the build. Falls back to
// today's date if git isn't available (tarball deploys, etc.).
let lastDeploy: string;
try {
  lastDeploy = execSync("git log -1 --format=%ad --date=short", {
    stdio: ["ignore", "pipe", "ignore"],
  })
    .toString()
    .trim();
} catch {
  lastDeploy = new Date().toISOString().slice(0, 10);
}
---
<div class="shell">
  <header class="shell-header">
    <div class="shell-inner">
      <span class="who">diego@sre</span>
      <span class="col">:</span>
      <span class="path">~/{segment}</span>
      <span class="prompt">$</span>
      <span class="header-right">
        <span class="domain">{site.domain}</span>
        <button class="theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle dark mode">
          <span class="when-light">☾</span>
          <span class="when-dark">☀</span>
        </button>
      </span>
    </div>
  </header>

  <nav class="shell-nav">
    <div class="shell-inner">
      {nav.map((n) => (
        <a href={n.href} aria-current={n.key === page ? "page" : undefined}>
          {n.key === page ? `[${n.label}]` : n.label}
        </a>
      ))}
    </div>
  </nav>

  <main class="shell-body">
    <div class="shell-inner">
      <slot />
    </div>
  </main>

  <footer class="shell-footer">
    <div class="shell-inner">
      <span>{"// "}last deploy {lastDeploy}</span>
      {site.links.map((l) => (
        <a href={l.url}>{l.label}</a>
      ))}
    </div>
  </footer>
</div>
<script is:inline>
  (function () {
    var btn = document.querySelector(".theme-toggle");
    if (!btn) return;
    btn.addEventListener("click", function () {
      var cur = document.documentElement.getAttribute("data-theme");
      var next = cur === "dark" ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      try { localStorage.setItem("theme", next); } catch (_) {}
    });
  })();
</script>
