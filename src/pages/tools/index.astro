---
import Base from "@/layouts/Base.astro";
import Shell from "@/layouts/Shell.astro";
import { tools } from "@/tools";
---
<Base title="tools">
  <Shell page="tools">
    <div class="heading-1"># tools</div>
    <div class="subtitle">small things that do one thing well. no tracking, no login.</div>

    <div style="margin-top:18px">
      {tools.map(({ meta }) => (
        <a class="tools-row" href={`/tools/${meta.slug}/`}>
          <div class="head">
            <span class="dollar">$</span>
            <span class="title">{meta.title}</span>
            <span class="slug">/{meta.slug}</span>
          </div>
          <div class="blurb">{meta.blurb}</div>
        </a>
      ))}
    </div>
  </Shell>
</Base>
