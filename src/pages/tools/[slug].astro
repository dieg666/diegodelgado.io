---
import Base from "@/layouts/Base.astro";
import Shell from "@/layouts/Shell.astro";
import { tools } from "@/tools";
import ErrorBudget from "@/tools/error-budget";

// To add a hydratable tool: import its component above and add a case below.
// The tool's meta lives in src/tools/<slug>/index.tsx and is picked up by the
// registry automatically — only interactive tools need this extra wiring, because
// Astro's client:* directives require static component imports.

export function getStaticPaths() {
  return tools.map(({ meta }) => ({
    params: { slug: meta.slug },
    props: { meta },
  }));
}

const { meta } = Astro.props;
---
<Base title={meta.title} description={meta.blurb}>
  <Shell page="tools" path={`tools/${meta.slug}`}>
    <div class="tool">
      <div class="breadcrumb">/ tools / {meta.slug}</div>
      <h1>{meta.title.toLowerCase()}</h1>
      <p class="pitch">{meta.blurb}</p>

      {meta.slug === "error-budget" ? (
        <ErrorBudget client:load />
      ) : (
        <div class="tool-placeholder">
          {"// "}coming soon. this tool is on the list — sketch lives in the changelog.
        </div>
      )}
    </div>
  </Shell>
</Base>
