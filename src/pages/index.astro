---
import Base from "@/layouts/Base.astro";
import Shell from "@/layouts/Shell.astro";
import { site } from "@/data/site";
import { tools } from "@/tools";
import { readStats } from "@/lib/read-stats";
import { getCollection } from "astro:content";

const all = await getCollection("writings", ({ data }) => !data.draft);
all.sort((a, b) => b.data.date.localeCompare(a.data.date));
const latest = all.slice(0, 4).map((w) => ({ ...w, stats: readStats(w.body) }));
const featuredTools = tools.slice(0, 3);
---
<Base>
  <Shell page="home">
    <div class="home-intro">diego delgado — senior sre, barcelona.</div>
    <div class="home-sub">{"// "}boring reliability, written down.</div>

    <div class="status-strip">
      <div>
        <span class="muted">status</span><br/>
        <span id="uptime-status" class="unknown">● unknown</span>
      </div>
      <div>
        <span class="muted">uptime 30d</span><br/>
        <span id="uptime-pct">—</span>
      </div>
      <div>
        <span class="muted">p95</span><br/>
        <span id="uptime-p95">—</span>
      </div>
    </div>
    <div class="dim" style="font-size:11px;margin-top:4px">last check <span id="uptime-last">—</span></div>

    <section class="section">
      <div class="heading-1">## now</div>
      <div class="dim" style="font-size:11px;margin-top:2px">updated {site.now.updated}</div>
      <ul style="margin:10px 0 0;padding-left:18px">
        {site.now.items.map((x) => <li style="margin-bottom:4px">{x}</li>)}
      </ul>
    </section>

    <section class="section">
      <div class="heading-1">## tools</div>
      <div style="margin-top:8px">
        {featuredTools.map(({ meta }) => (
          <a class="home-tools-row" href={`/tools/${meta.slug}/`}>
            <span>→ {meta.title}</span>
            <span class="blurb">{meta.blurb}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="heading-1">## latest</div>
      <div style="margin-top:8px">
        {latest.map((w) => (
          <a class="home-latest-row" href={`/writings/${w.slug}/`}>
            <span class="date">{w.data.date}</span>
            <span>{w.data.title}</span>
            <span class="read-min">{w.stats.read}min</span>
          </a>
        ))}
      </div>
    </section>
  </Shell>
</Base>
<script>
  type UptimeStatus = "ok" | "down" | "unknown";
  interface LastCheck {
    ts: number;
    ok: boolean;
    http_status: number;
    latency_ms: number;
  }
  interface UptimePayload {
    status: UptimeStatus;
    uptime_pct: number | null;
    p95_ms: number | null;
    checks: number;
    last_check: LastCheck | null;
  }

  function relativeTime(tsSec: number): string {
    const diff = Math.max(0, Math.floor(Date.now() / 1000 - tsSec));
    if (diff < 60) return `${diff}s ago`;
    if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
    return `${Math.floor(diff / 86400)}d ago`;
  }

  (async () => {
    const ctl = new AbortController();
    const timer = setTimeout(() => ctl.abort(), 4000);
    try {
      const res = await fetch("/api/uptime", { signal: ctl.signal });
      if (!res.ok) return;
      const data = (await res.json()) as UptimePayload;

      const statusEl = document.getElementById("uptime-status");
      if (statusEl) {
        statusEl.className =
          data.status === "ok" ? "ok" : data.status === "down" ? "down" : "unknown";
        statusEl.textContent = `● ${data.status}`;
      }
      const pctEl = document.getElementById("uptime-pct");
      if (pctEl && data.uptime_pct != null) {
        pctEl.textContent = `${data.uptime_pct.toFixed(2)}%`;
      }
      const p95El = document.getElementById("uptime-p95");
      if (p95El && data.p95_ms != null) {
        p95El.textContent = `${Math.round(data.p95_ms)}ms`;
      }
      const lastEl = document.getElementById("uptime-last");
      if (lastEl && data.last_check) {
        const ts = data.last_check.ts;
        lastEl.textContent = relativeTime(ts);
        setInterval(() => {
          lastEl.textContent = relativeTime(ts);
        }, 30_000);
      }
    } catch {
    } finally {
      clearTimeout(timer);
    }
  })();
</script>
